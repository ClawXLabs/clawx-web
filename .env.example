# Avalanche Fuji Testnet Configuration
# Use the same key in both if you want one wallet for deploy + relayer. Hardhat uses PRIVATE_KEY first, then SETTLEMENT_PRIVATE_KEY.
PRIVATE_KEY=your_private_key_here
SETTLEMENT_PRIVATE_KEY=your_funded_fuji_relayer_private_key_here
FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
AVALANCHE_API_KEY=your_snowtrace_api_key_here
# Latest Fuji deploy (Tusdc + market); override when you redeploy.
NEXT_PUBLIC_CONTRACT_ADDRESS=0x378FBf873fF77a44ae9aac0B5427804A9Ec1Bf1d
NEXT_PUBLIC_COLLATERAL_TOKEN_ADDRESS=0xd27D2AB610714E262E64c7BFA789769A98A5DeB1
# Tusdc (TUSDC) test token — deploy with npm run deploy:tusdc
NEXT_PUBLIC_TUSDC_ADDRESS=0xd27D2AB610714E262E64c7BFA789769A98A5DeB1
# Optional: browser read-only RPC for leaderboard (defaults to public Fuji)
NEXT_PUBLIC_FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc

# App backend used by landing "Add Wallet" / hero stats (defaults to production)
# NEXT_PUBLIC_APP_API_URL=https://app.clawxlab.xyz
# NEXT_PUBLIC_APP_URL=https://app.clawxlab.xyz

# Faucet mints TUSDC — must be the Tusdc contract owner (usually same as PRIVATE_KEY used to deploy Tusdc).
# If unset, the API tries PRIVATE_KEY then SETTLEMENT_PRIVATE_KEY.
# FAUCET_PRIVATE_KEY=
# Seconds between faucet claims per address (default 86400). Use 0 for frictionless local testing; delete data/faucet-claims.json to reset who claimed.
# FAUCET_COOLDOWN_SEC=0

FAST_ORACLE_ADDRESSES={"AVAX":"deployed_fast_oracle","BNB":"deployed_fast_oracle","BTC":"deployed_fast_oracle","ETH":"deployed_fast_oracle","NEAR":"deployed_fast_oracle"}

# Fast oracle sources are fetched server-side from Binance, Coinbase, and Gate.io.

# --- Optional: relayer-paid trades (no Fuji AVAX needed in the user's wallet) ---
# After redeploying PredictionMarket with buyPositionFor / sellPositionFor / claimWinningsFor and Tusdc with ERC20Permit:
# NEXT_PUBLIC_TRADE_RELAY=true
# The same SETTLEMENT_PRIVATE_KEY wallet must be allowed as settlement operator on the market contract (owner or settlementOperator).

# --- Autonomous agents (lobby at /agents) — trades 24/7, same hours as manual ---
# Optional; default dev-agent-runner matches npm run agent-runner locally
# AGENT_RUNNER_SECRET=dev-agent-runner
# APP_URL=http://localhost:3000
# AGENT_RUNNER_POLL_MS=30000
# AGENT_MIN_TRADE_GAP_SEC=90
# Optional: real AI (OpenAI-compatible). Recommended free provider: Google Gemini (AI Studio).
# AGENT_LLM_API_KEY=your_gemini_api_key
# AGENT_LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# AGENT_LLM_MODEL=gemini-2.0-flash
# AGENT_LLM_COOLDOWN_SEC=180
# Optional showcase wallets for live catalog AUM (Bone Reaper style leaderboard)
# NEXT_PUBLIC_AGENT_MOMENTUM_ADDRESS=
# NEXT_PUBLIC_AGENT_FADE_ADDRESS=
# NEXT_PUBLIC_AGENT_SNIPER_ADDRESS=
# NEXT_PUBLIC_AGENT_BALANCED_ADDRESS=
