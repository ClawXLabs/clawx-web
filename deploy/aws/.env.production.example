# ClawX production — copy to /opt/clawx/.env

# ── Relayer / settlement wallet (needs Fuji AVAX for gas) ──
SETTLEMENT_PRIVATE_KEY=
PRIVATE_KEY=

# ── Fuji RPC (use Alchemy/Infura in production — not the public default) ──
FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
NEXT_PUBLIC_FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc

# ── Deployed market + TUSDC ──
NEXT_PUBLIC_CONTRACT_ADDRESS=
NEXT_PUBLIC_COLLATERAL_TOKEN_ADDRESS=
NEXT_PUBLIC_TUSDC_ADDRESS=
NEXT_PUBLIC_TRADE_RELAY=true

# ── Fast oracle addresses (JSON map symbol → address) ──
FAST_ORACLE_ADDRESSES=

# ── Public URL — agent-runner calls APP_URL/api/agents/execute ──
APP_URL=https://yourdomain.com

# ── Agent runner auth (long random string) ──
AGENT_RUNNER_SECRET=change-me-in-production
AGENT_RUNNER_POLL_MS=4000

# ── Optional: live LLM for agent memory / reasoning ──
AGENT_LLM_API_KEY=
AGENT_LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
AGENT_LLM_MODEL=gemini-2.0-flash
AGENT_LLM_COOLDOWN_SEC=180

# ── Supabase — agent backend (enrollments, profiles, feed) ──
# Get from: Supabase Dashboard → Settings → API / Database
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=   # only if adding client-side reads later

# ── Faucet ──
FAUCET_COOLDOWN_SEC=86400
